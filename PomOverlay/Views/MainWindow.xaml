<Window x:Class="PomOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PomOverlay" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Grid>
        <Rectangle x:Name="AuroraRect" Margin="0">
            <Rectangle.Stroke>
                <LinearGradientBrush x:Name="AuroraBrush" 
                     StartPoint="0,0" EndPoint="1,1" 
                     SpreadMethod="Repeat">
                    <LinearGradientBrush.RelativeTransform>
                        <TranslateTransform x:Name="BrushTransform" />
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Offset="0.0" Color="Transparent" />
                    <GradientStop Offset="0.16" Color="Transparent" />
                    <GradientStop Offset="0.33" Color="Transparent" />
                    <GradientStop Offset="0.5" Color="Transparent" />
                    <GradientStop Offset="0.66" Color="Transparent" />
                    <GradientStop Offset="0.83" Color="Transparent" />
                    <GradientStop Offset="1.0" Color="Transparent" />
                </LinearGradientBrush>
            </Rectangle.Stroke>
            <Rectangle.Effect>
                <BlurEffect x:Name="BlurEff" Radius="10" />
            </Rectangle.Effect>
        </Rectangle>

        <Border x:Name="DebugContainer" 
                Background="#AA000000" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Left" 
                Padding="10" 
                Margin="20" 
                CornerRadius="5"
                Visibility="Collapsed">
            <TextBlock x:Name="DebugText" 
                       FontFamily="BIZ UDゴシック, MS Gothic, Consolas"
                       FontSize="18" 
                       Foreground="Lime"
                       LineHeight="16"/>
        </Border>
    </Grid>
</Window>